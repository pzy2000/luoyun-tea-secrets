    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect, useRef } from \"react\";\nimport { \n  BookOpen, \n  Sparkles, \n  Sliders, \n  Volume2, \n  VolumeX, \n  RotateCcw, \n  ChevronRight, \n  ChevronLeft, \n  Trash2, \n  FileText, \n  Feather, \n  Check, \n  Loader2,\n  BookOpenText,\n  Compass\n} from \"lucide-react\";\nimport { INITIAL_CHAPTERS, PRESET_PROMPTS, REASSURING_MESSAGES, Chapter } from \"./data\";\n\n// Type definitions for reading settings\ninterface ReaderSettings {\n  theme: \"mystic-dark\" | \"silk-light\" | \"bamboo-green\";\n  fontFamily: \"font-sans\" | \"font-serif\" | \"font-mono\";\n  fontSize: number; // in pixels\n  autoScroll: boolean;\n  scrollSpeed: number; // index or value\n}\n\nexport default function App() {\n  // Novel chapters state\n  const [chapters, setChapters] = useState<Chapter[]>(() => {\n    const saved = localStorage.getItem(\"luoyun_chapters\");\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {\n        console.error(\"Failed to parse saved chapters, resetting\", e);\n      }\n    }\n    return INITIAL_CHAPTERS;\n  });\n\n  // Selected chapter\n  const [selectedId, setSelectedId] = useState<number>(1);\n  const currentChapter = chapters.find(c => c.id === selectedId) || chapters[0] || INITIAL_CHAPTERS[0];\n\n  // Settings state\n  const [settings, setSettings] = useState<ReaderSettings>(() => {\n    const saved = localStorage.getItem(\"luoyun_settings\");\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {}\n    }\n    return {\n      theme: \"mystic-dark\",\n      fontFamily: \"font-serif\",\n      fontSize: 18,\n      autoScroll: false,\n      scrollSpeed: 20\n    };\n  });\n\n  // AI prompt state\n  const [prompt, setPrompt] = useState<string>(\"\");\n  const [isGenerating, setIsGenerating] = useState<boolean>(false);\n  const [loadingStep, setLoadingStep] = useState<string>(\"\");\n  const [errorMsg, setErrorMsg] = useState<string | null>(null);\n\n  // Audio environment states\n  const [ambientPlaying, setAmbientPlaying] = useState<boolean>(false);\n  const [ambientVolume, setAmbientVolume] = useState<number>(0.3);\n  const audioContextRef = useRef<AudioContext | null>(null);\n  const noiseSourceNodeRef = useRef<AudioWorkletNode | ScriptProcessorNode | null>(null);\n  const gainNodeRef = useRef<GainNode | null>(null);\n  const filterNodeRef = useRef<BiquadFilterNode | null>(null);\n  const lfoRef = useRef<OscillatorNode | null>(null);\n\n  // Auto-scroll ref & timer\n  const scrollContainerRef = useRef<HTMLDivElement | null>(null);\n  const scrollIntervalRef = useRef<number | null>(null);\n\n  // Persist chapters\n  useEffect(() => {\n    localStorage.setItem(\"luoyun_chapters\", JSON.stringify(chapters));\n  }, [chapters]);\n\n  // Persist settings\n  useEffect(() => {\n    localStorage.setItem(\"luoyun_settings\", JSON.stringify(settings));\n  }, [settings]);\n\n  // Auto-scroll implementation\n  useEffect(() => {\n    if (settings.autoScroll && scrollContainerRef.current) {\n      const container = scrollContainerRef.current;\n      \n      if (scrollIntervalRef.current) {\n        clearInterval(scrollIntervalRef.current);\n      }\n\n      // Convert speed setting (10 to 50) to millisecond intervals\n      const intervalMs = Math.max(10, 100 - settings.scrollSpeed);\n      \n      scrollIntervalRef.current = window.setInterval(() => {\n        if (container) {\n          // If already scrolled to bottom, stop auto scrolling\n          if (container.scrollTop + container.clientHeight >= container.scrollHeight - 5) {\n            setSettings(prev => ({ ...prev, autoScroll: false }));\n          } else {\n            container.scrollTop += 1;\n          }\n        }\n      }, intervalMs);\n    } else {\n      if (scrollIntervalRef.current) {\n        clearInterval(scrollIntervalRef.current);\n        scrollIntervalRef.current = null;\n      }\n    }\n\n    return () => {\n      if (scrollIntervalRef.current) {\n        clearInterval(scrollIntervalRef.current);\n      }\n    };\n  }, [settings.autoScroll, settings.scrollSpeed, selectedId]);\n\n  // AI Loading Screen Steps Rotator\n  useEffect(() => {\n    let interval: number;\n    if (isGenerating) {\n      let index = 0;\n      setLoadingStep(REASSURING_MESSAGES[0]);\n      interval = window.setInterval(() => {\n        index = (index + 1) % REASSURING_MESSAGES.length;\n        setLoadingStep(REASSURING_MESSAGES[index]);\n      }, 3500);\n    }\n    return () => {\n      if (interval) clearInterval(interval);\n    };\n  }, [isGenerating]);\n\n  // Ambient Synthesizer using Web Audio API\n  const startAmbience = () => {\n    try {\n      if (!audioContextRef.current) {\n        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;\n        audioContextRef.current = new AudioContextClass();\n      }\n\n      const ctx = audioContextRef.current;\n      if (ctx.state === \"suspended\") {\n        ctx.resume();\n      }\n\n      // Create Gain Node for volume\n      const gainNode = ctx.createGain();\n      gainNode.gain.value = ambientVolume;\n      gainNodeRef.current = gainNode;\n\n      // Create Bandpass filter for wind modulation\n      const filter = ctx.createBiquadFilter();\n      filter.type = \"bandpass\";\n      filter.Q.value = 3.0;\n      filterNodeRef.current = filter;\n\n      // Generate brown noise buffer for rustling leaves/wind\n      const bufferSize = 2 * ctx.sampleRate;\n      const noiseBuffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);\n      const output = noiseBuffer.getChannelData(0);\n      let lastOut = 0.0;\n      for (let i = 0; i < bufferSize; i++) {\n        const white = Math.random() * 2 - 1;\n        output[i] = (lastOut + (0.02 * white)) / 1.02;\n        lastOut = output[i];\n        output[i] *= 3.5; // Amplify slightly\n      }\n\n      const noiseSource = ctx.createBufferSource();\n      noiseSource.buffer = noiseBuffer;\n      noiseSource.loop = true;\n\n      // Low frequency oscillator (LFO) to modulate wind intensity\n      const lfo = ctx.createOscillator();\n      lfo.frequency.value = 0.12; // Modulate wind once every ~8 seconds\n\n      const lfoGain = ctx.createGain();\n      lfoGain.gain.value = 250; // Filter cutoff swing frequency\n\n      // Connect LFO modulation\n      lfo.connect(lfoGain);\n      lfoGain.connect(filter.frequency);\n\n      // Base filter cutoff\n      filter.frequency.value = 600;\n\n      // Connect nodes\n      noiseSource.connect(filter);\n      filter.connect(gainNode);\n      gainNode.connect(ctx.destination);\n\n      // Start oscillators and noise\n      noiseSource.start();\n      lfo.start();\n\n      // Store node references for cancellation\n      (noiseSourceNodeRef as any).current = noiseSource;\n      lfoRef.current = lfo;\n\n      setAmbientPlaying(true);\n    } catch (e) {\n      console.error(\"Web Audio API failed to initialize\", e);\n    }\n  };\n\n  const stopAmbience = () => {\n    try {\n      if ((noiseSourceNodeRef as any).current) {\n        (noiseSourceNodeRef as any).current.stop();\n        (noiseSourceNodeRef as any).current.disconnect();\n        (noiseSourceNodeRef as any).current = null;\n      }\n      if (lfoRef.current) {\n        lfoRef.current.stop();\n        lfoRef.current.disconnect();\n        lfoRef.current = null;\n      }\n      if (filterNodeRef.current) {\n        filterNodeRef.current.disconnect();\n        filterNodeRef.current = null;\n      }\n      if (gainNodeRef.current) {\n        gainNodeRef.current.disconnect();\n        gainNodeRef.current = null;\n      }\n      setAmbientPlaying(false);\n    } catch (e) {\n      console.error(\"Web Audio API failed to stop\", e);\n    }\n  };\n\n  // Handle volume changes\n  useEffect(() => {\n    if (gainNodeRef.current && audioContextRef.current) {\n      gainNodeRef.current.gain.setValueAtTime(ambientVolume, audioContextRef.current.currentTime);\n    }\n  }, [ambientVolume]);\n\n  const toggleAmbience = () => {\n    if (ambientPlaying) {\n      stopAmbience();\n    } else {\n      startAmbience();\n    }\n  };\n\n  // Reset to original chapters\n  const resetChapters = () => {\n    if (confirm(\"\347\241\256\350\256\244\351\207\215\347\275\256\345\220\227\357\274\237\350\277\231\345\260\206\346\270\205\351\231\244\346\211\200\346\234\211 AI \347\273\255\345\206\231\347\232\204\347\253\240\350\212\202\357\274\214\345\217\252\344\277\235\347\225\231\350\220\275\344\272\221\345\256\227\345\211\215\345\205\255\347\253\240\345\216\237\350\221\227\343\200\202\")) {\n      setChapters(INITIAL_CHAPTERS);\n      setSelectedId(1);\n    }\n  };\n\n  // Delete current selected chapter (only if it is custom)\n  const deleteCurrentChapter = () => {\n    if (chapters.length <= 1) return;\n    if (confirm(`\347\241\256\350\256\244\345\210\240\351\231\244\347\253\240\350\212\202\343\200\212${currentChapter.title}\343\200\213\345\220\227\357\274\237`)) {\n      const remaining = chapters.filter(c => c.id !== currentChapter.id);\n      // Re-index remaining chapters to maintain proper IDs\n      const reindexed = remaining.map((chap, idx) => ({\n        ...chap,\n        id: idx + 1\n      }));\n      setChapters(reindexed);\n      setSelectedId(reindexed[reindexed.length - 1].id);\n    }\n  };\n\n  // Generate Next Chapter via Server-side Gemini Proxy\n  const generateNextChapter = async () => {\n    if (isGenerating) return;\n    if (!prompt.trim()) {\n      setErrorMsg(\"\350\257\267\345\205\210\345\234\250\345\217\263\344\276\247\350\276\223\345\205\245\346\241\206\345\206\231\345\205\245\346\210\226\351\200\211\346\213\251\344\270\200\344\270\252\345\211\247\346\203\205\350\265\260\345\220\221\346\217\220\347\244\272\343\200\202\");\n      return;\n    }\n\n    setIsGenerating(true);\n    setErrorMsg(null);\n\n    // Compile full novel text context for Gemini to read\n    const novelHistory = chapters\n      .map(c => `\343\200\220${c.title}\343\200\221\\n${c.content}`)\n      .join(\"\\n\\n\");\n\n    try {\n      const res = await fetch(\"/api/generate\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          history: novelHistory,\n          prompt: prompt\n        })\n      });\n\n      const data = await res.json();\n\n      if (!res.ok) {\n        throw new Error(data.error || \"\350\257\267\346\261\202\346\234\215\345\212\241\345\231\250\345\244\261\350\264\245\357\274\214\350\257\267\347\241\256\344\277\235\347\247\230\345\257\206\345\257\206\351\222\245\351\205\215\347\275\256\346\255\243\347\241\256\343\200\202\");\n      }\n\n      // Successfully generated next chapter\n      const newId = chapters.length + 1;\n      const newChapter: Chapter = {\n        id: newId,\n        title: `\347\254\254${newId}\347\253\240\357\274\232${prompt.length > 12 ? prompt.slice(0, 12) + \"...\" : prompt}`,\n        subtitle: `AI \347\273\255\345\206\231\350\207\252\357\274\232${prompt.length > 20 ? prompt.slice(0, 20) + \"...\" : prompt}`,\n        content: data.text,\n        isAiGenerated: true,\n        promptUsed: prompt\n      };\n\n      setChapters(prev => [...prev, newChapter]);\n      setSelectedId(newId);\n      setPrompt(\"\"); // Reset input\n\n      // Scroll reader back to top smoothly\n      if (scrollContainerRef.current) {\n        scrollContainerRef.current.scrollTop = 0;\n      }\n    } catch (err: any) {\n      console.error(err);\n      setErrorMsg(err.message || \"\347\224\237\346\210\220\345\244\261\350\264\245\357\274\214\345\217\257\350\203\275\346\202\250\347\232\204 GEMINI_API_KEY \346\227\240\346\225\210\346\210\226\345\217\227\351\231\220\343\200\202\");\n    } finally {\n      setIsGenerating(false);\n    }\n  };\n\n  // Fast select prompt shortcut\n  const selectPresetPrompt = (preset: string) => {\n    setPrompt(preset);\n  };\n\n  // Theme styling configurations\n  const getThemeClasses = () => {\n    switch (settings.theme) {\n      case \"silk-light\":\n        return {\n          appBg: \"bg-stone-100 text-stone-900 selection:bg-emerald-100\",\n          cardBg: \"bg-white border-stone-200/80 shadow-md shadow-stone-200/50\",\n          textMuted: \"text-stone-500\",\n          textTitle: \"text-stone-800\",\n          accentColor: \"text-emerald-700 bg-emerald-50 border-emerald-200\",\n          accentText: \"text-emerald-700\",\n          accentBorder: \"border-emerald-200\",\n          accentBtn: \"bg-emerald-700 hover:bg-emerald-800 text-white shadow-emerald-700/10\",\n          sidebarActive: \"bg-emerald-50 text-emerald-800 border-l-4 border-emerald-700\",\n          sidebarHover: \"hover:bg-stone-50\",\n          inputBg: \"bg-stone-50 border-stone-200 text-stone-900 focus:border-emerald-500\",\n          readerBg: \"bg-stone-50/50 border-stone-200\"\n        };\n      case \"bamboo-green\":\n        return {\n          appBg: \"bg-emerald-950 text-emerald-100 selection:bg-yellow-950/80\",\n          cardBg: \"bg-emerald-900/40 border-emerald-800/80 backdrop-blur-md shadow-lg shadow-emerald-950/20\",\n          textMuted: \"text-emerald-400\",\n          textTitle: \"text-emerald-200\",\n          accentColor: \"text-yellow-400 bg-yellow-950/30 border-yellow-800/50\",\n          accentText: \"text-yellow-400\",\n          accentBorder: \"border-yellow-800/50\",\n          accentBtn: \"bg-yellow-500 hover:bg-yellow-600 text-emerald-950 font-semibold shadow-yellow-500/10\",\n          sidebarActive: \"bg-emerald-850 text-yellow-300 border-l-4 border-yellow-500\",\n          sidebarHover: \"hover:bg-emerald-900/30\",\n          inputBg: \"bg-emerald-950/50 border-emerald-800 text-emerald-100 focus:border-yellow-500\",\n          readerBg: \"bg-emerald-950/30 border-emerald-800/50\"\n        };\n      case \"mystic-dark\":\n      default:\n        return {\n          appBg: \"bg-slate-950 text-slate-100 selection:bg-amber-950/80\",\n          cardBg: \"bg-slate-900/70 border-slate-800 backdrop-blur-md shadow-xl shadow-black/40\",\n          textMuted: \"text-slate-400\",\n          textTitle: \"text-slate-200\",\n          accentColor: \"text-amber-400 bg-amber-950/30 border-amber-900/50\",\n          accentText: \"text-amber-400\",\n          accentBorder: \"border-amber-900/50\",\n          accentBtn: \"bg-amber-500 hover:bg-amber-600 text-slate-950 font-semibold shadow-amber-500/10\",\n          sidebarActive: \"bg-slate-850 text-amber-300 border-l-4 border-amber-500\",\n          sidebarHover: \"hover:bg-slate-900/30\",\n          inputBg: \"bg-slate-950/50 border-slate-800 text-slate-100 focus:border-amber-500\",\n          readerBg: \"bg-slate-950/30 border-slate-800/50\"\n        };\n    }\n  };\n\n  const themeClasses = getThemeClasses();\n\n  return (\n    <div className={`min-h-screen ${themeClasses.appBg} flex flex-col transition-all duration-500 relative overflow-hidden font-sans`}>\n      {/* Visual background details to establish atmosphere */}\n      <div className=\"absolute inset-0 pointer-events-none opacity-20 overflow-hidden\">\n        <div className=\"absolute top-10 left-10 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl\"></div>\n        <div className=\"absolute bottom-20 right-10 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl\"></div>\n        <div className=\"absolute top-1/3 right-1/4 w-80 h-80 bg-slate-500/10 rounded-full blur-3xl\"></div>\n      </div>\n\n      {/* Header Bar */}\n      <header className={`z-10 border-b ${themeClasses.cardBg} px-6 py-4 flex items-center justify-between transition-all duration-300`}>\n        <div className=\"flex items-center space-x-3\">\n          <div className=\"p-2.5 rounded-xl bg-amber-500/10 border border-amber-500/20\">\n            <Feather className={`w-6 h-6 ${themeClasses.accentText}`} />\n          </div>\n          <div>\n            <h1 className=\"text-xl font-bold tracking-wider font-serif flex items-center gap-2\">\n              \350\220\275\344\272\221\344\277\256\344\273\231\344\274\240 <span className=\"text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-300 border border-amber-500/30 font-sans\">\347\201\265\350\214\266\347\247\230\350\257\235</span>\n            </h1>\n            <p className={`text-xs ${themeClasses.textMuted}`}>\345\220\271\350\214\266\344\273\231\345\255\220\345\256\213\347\216\211 \303\227 \345\205\203\345\251\264\345\244\247\350\203\275\351\237\251\347\253\213\347\232\204\347\246\201\345\277\214\345\256\277\345\221\275\345\217\214\344\277\256</p>\n          </div>\n        </div>\n\n        {/* Sensory audio ambient synthesiser controls */}\n        <div className=\"flex items-center space-x-4\">\n          <div className=\"hidden md:flex items-center space-x-3 bg-slate-950/40 px-3 py-1.5 rounded-xl border border-slate-800\">\n            <button\n              onClick={toggleAmbience}\n              className={`p-1.5 rounded-lg transition-colors ${\n                ambientPlaying ? \"bg-emerald-500/20 text-emerald-400\" : \"hover:bg-slate-800 text-slate-400\"\n              }`}\n              title=\"\346\222\255\346\224\276\351\235\231\345\256\244\347\253\271\346\236\227\351\233\250\347\231\275\345\231\252\351\237\263 (Web Audio \345\220\210\346\210\220\345\231\250)\"\n            >\n              {ambientPlaying ? <Volume2 className=\"w-4 h-4 animate-pulse\" /> : <VolumeX className=\"w-4 h-4\" />}\n            </button>\n            <div className=\"flex flex-col\">\n              <span className=\"text-[10px] text-slate-400 font-mono\">\351\235\231\345\256\244\347\247\230\345\242\203\347\231\275\345\231\252\351\237\263</span>\n              <div className=\"flex items-center space-x-1.5\">\n                <input\n                  type=\"range\"\n                  min=\"0\"\n                  max=\"1\"\n                  step=\"0.05\"\n                  value={ambientVolume}\n                  onChange={(e) => setAmbientVolume(parseFloat(e.target.value))}\n                  disabled={!ambientPlaying}\n                  className=\"w-16 h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-amber-500 disabled:opacity-50\"\n                />\n                <span className=\"text-[9px] text-slate-500 font-mono\">{Math.round(ambientVolume * 100)}%</span>\n              </div>\n            </div>\n          </div>\n\n          <button\n            onClick={resetChapters}\n            className={`flex items-center space-x-1 px-3 py-1.5 rounded-lg border text-xs transition-all ${themeClasses.sidebarHover} ${themeClasses.accentBorder}`}\n            title=\"\351\207\215\347\275\256\345\260\217\350\257\264\345\216\237\350\221\227\"\n          >\n            <RotateCcw className=\"w-3.5 h-3.5\" />\n            <span className=\"hidden sm:inline\">\351\207\215\347\275\256\345\205\250\344\271\246</span>\n          </button>\n        </div>\n      </header>\n\n      {/* Main Container */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch relative z-10\">\n        \n        {/* Left Side: Chapter Navigation & Customizer */}\n        <section className=\"lg:col-span-3 flex flex-col space-y-4\">\n          \n          {/* Section: Reading Customization Panel */}\n          <div className={`p-4 rounded-2xl border ${themeClasses.cardBg} transition-all duration-300 flex flex-col space-y-3.5`}>\n            <h2 className=\"text-sm font-semibold tracking-wider font-serif flex items-center space-x-1.5\">\n              <Sliders className=\"w-4 h-4 text-amber-500\" />\n              <span>\351\235\231\345\256\244\351\230\205\350\257\273\345\201\217\345\245\275</span>\n            </h2>\n            \n            {/* Customizer: Theme Select */}\n            <div className=\"space-y-1.5\">\n              <span className={`text-[11px] font-mono tracking-wider ${themeClasses.textMuted} uppercase`}>\347\247\230\345\242\203\346\260\233\345\233\264 (\350\203\214\346\231\257)</span>\n              <div className=\"grid grid-cols-3 gap-1.5\">\n                <button\n                  onClick={() => setSettings(prev => ({ ...prev, theme: \"mystic-dark\" }))}\n                  className={`py-1 text-[11px] rounded-lg border transition-all ${\n                    settings.theme === \"mystic-dark\" \n                      ? \"bg-amber-500/20 border-amber-500 text-amber-300 font-semibold\" \n                      : \"bg-slate-900 border-slate-800 text-slate-400 hover:border-slate-700\"\n                  }`}\n                >\n                  \345\271\275\351\246\231\351\235\231\345\256\244\n                </button>\n                <button\n                  onClick={() => setSettings(prev => ({ ...prev, theme: \"bamboo-green\" }))}\n                  className={`py-1 text-[11px] rounded-lg border transition-all ${\n                    settings.theme === \"bamboo-green\" \n                      ? \"bg-yellow-950/40 border-yellow-500 text-yellow-300 font-semibold\" \n                      : \"bg-emerald-950 border-emerald-900 text-emerald-400 hover:border-emerald-800\"\n                  }`}\n                >\n                  \347\253\271\346\236\227\346\267\261\345\244\204\n                </button>\n                <button\n                  onClick={() => setSettings(prev => ({ ...prev, theme: \"silk-light\" }))}\n                  className={`py-1 text-[11px] rounded-lg border transition-all ${\n                    settings.theme === \"silk-light\" \n                      ? \"bg-emerald-500/10 border-emerald-700 text-emerald-800 font-semibold\" \n                      : \"bg-stone-50 border-stone-200 text-stone-500 hover:border-stone-400\"\n                  }`}\n                >\n                  \346\234\210\347\231\275\350\275\273\347\272\261\n                </button>\n              </div>\n            </div>\n\n            {/* Customizer: Fonts Select */}\n            <div className=\"space-y-1.5\">\n              <span className={`text-[11px] font-mono tracking-wider ${themeClasses.textMuted} uppercase`}>\351\201\223\345\277\203\344\275\223\346\202\237 (\345\255\227\344\275\223)</span>\n              <div className=\"grid grid-cols-3 gap-1.5\">\n                <button\n                  onClick={() => setSettings(prev => ({ ...prev, fontFamily: \"font-serif\" }))}\n                  className={`py-1 text-xs rounded-lg border font-serif transition-all ${\n                    settings.fontFamily === \"font-serif\" \n                      ? \"border-amber-500 text-amber-400 font-semibold bg-amber-500/10\" \n                      : \"border-transparent bg-slate-950/30 text-slate-400\"\n                  }`}\n                >\n                  \345\256\213\344\275\223\351\233\205\350\207\264\n                </button>\n                <button\n                  onClick={() => setSettings(prev => ({ ...prev, fontFamily: \"font-sans\" }))}\n                  className={`py-1 text-xs rounded-lg border font-sans transition-all ${\n                    settings.fontFamily === \"font-sans\" \n                      ? \"border-amber-500 text-amber-400 font-semibold bg-amber-500/10\" \n                      : \"border-transparent bg-slate-950/30 text-slate-400\"\n                  }`}\n                >\n                  \347\216\260\344\273\243\346\227\240\350\241\254\n                </button>\n                <button\n                  onClick={() => setSettings(prev => ({ ...prev, fontFamily: \"font-mono\" }))}\n                  className={`py-1 text-xs rounded-lg border font-mono transition-all ${\n                    settings.fontFamily === \"font-mono\" \n                      ? \"border-amber-500 text-amber-400 font-semibold bg-amber-500/10\" \n                      : \"border-transparent bg-slate-950/30 text-slate-400\"\n                  }`}\n                >\n                  \346\236\201\345\256\242\347\255\211\345\256\275\n                </button>\n              </div>\n            </div>\n\n            {/* Customizer: Font Size */}\n            <div className=\"space-y-1\">\n              <div className=\"flex justify-between items-center text-[11px]\">\n                <span className={`font-mono tracking-wider ${themeClasses.textMuted} uppercase`}>\347\216\211\347\256\200\345\255\227\345\217\267 (\345\244\247\345\260\217)</span>\n                <span className=\"font-mono text-amber-400\">{settings.fontSize}px</span>\n              </div>\n              <div className=\"flex items-center space-x-2\">\n                <span className=\"text-xs text-slate-500\">A-</span>\n                <input\n                  type=\"range\"\n                  min=\"14\"\n                  max=\"28\"\n                  step=\"1\"\n                  value={settings.fontSize}\n                  onChange={(e) => setSettings(prev => ({ ...prev, fontSize: parseInt(e.target.value) }))}\n                  className=\"flex-1 h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-amber-500\"\n                />\n                <span className=\"text-xs text-slate-500\">A+</span>\n              </div>\n            </div>\n\n            {/* Customizer: Auto Scroll settings */}\n            <div className=\"pt-2 border-t border-slate-800/40 space-y-2\">\n              <label className=\"flex items-center justify-between cursor-pointer group\">\n                <span className=\"text-xs font-mono text-slate-400 group-hover:text-amber-300 transition-colors\">\345\274\200\345\220\257\347\245\236\350\257\206\350\207\252\345\212\250\345\236\202\351\230\205 (\350\207\252\345\212\250\347\277\273\351\241\265)</span>\n                <input\n                  type=\"checkbox\"\n                  checked={settings.autoScroll}\n                  onChange={(e) => setSettings(prev => ({ ...prev, autoScroll: e.target.checked }))}\n                  className=\"sr-only peer\"\n                />\n                <div className=\"relative w-8 h-4 bg-slate-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[\'\'] after:absolute after:top-[2px] after:start-[2px] after:bg-slate-400 after:border-slate-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-amber-500 peer-checked:after:bg-slate-950\"></div>\n              </label>\n\n              {settings.autoScroll && (\n                <div className=\"space-y-1 animate-fadeIn\">\n                  <div className=\"flex justify-between items-center text-[10px]\">\n                    <span className=\"text-slate-500\">\350\277\220\350\275\254\345\221\250\345\244\251\351\200\237\345\272\246</span>\n                    <span className=\"font-mono text-amber-400\">{settings.scrollSpeed} \350\277\210/\347\247\222</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"1\"\n                    max=\"50\"\n                    value={settings.scrollSpeed}\n                    onChange={(e) => setSettings(prev => ({ ...prev, scrollSpeed: parseInt(e.target.value) }))}\n                    className=\"w-full h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-amber-500\"\n                  />\n                </div>\n              )}\n            </div>\n          </div>\n\n          {/* Section: Interactive Chapter Table of Contents */}\n          <div className={`flex-1 p-4 rounded-2xl border ${themeClasses.cardBg} transition-all duration-300 flex flex-col space-y-3 overflow-hidden min-h-[300px]`}>\n            <div className=\"flex items-center justify-between\">\n              <h2 className=\"text-sm font-semibold tracking-wider font-serif flex items-center space-x-1.5\">\n                <BookOpen className=\"w-4 h-4 text-amber-500\" />\n                <span>\350\220\275\344\272\221\347\247\230\345\275\225\347\216\211\347\256\200</span>\n              </h2>\n              <span className={`text-[10px] font-mono px-1.5 py-0.5 rounded ${themeClasses.accentColor}`}>\n                \345\205\261 {chapters.length} \345\215\267\n              </span>\n            </div>\n\n            <div className=\"flex-1 overflow-y-auto pr-1 space-y-2 max-h-[350px] lg:max-h-none\">\n              {chapters.map((chap) => {\n                const isSelected = chap.id === selectedId;\n                return (\n                  <button\n                    key={chap.id}\n                    onClick={() => {\n                      setSelectedId(chap.id);\n                      if (scrollContainerRef.current) scrollContainerRef.current.scrollTop = 0;\n                    }}\n                    className={`w-full text-left p-2.5 rounded-xl transition-all duration-200 border text-xs relative ${\n                      isSelected \n                        ? themeClasses.sidebarActive + \" border-transparent\"\n                        : \"border-transparent \" + themeClasses.sidebarHover + ` ${themeClasses.inputBg}`\n                    }`}\n                  >\n                    <div className=\"flex items-center justify-between\">\n                      <span className=\"font-bold font-serif truncate max-w-[85%]\">{chap.title}</span>\n                      {chap.isAiGenerated && (\n                        <Sparkles className=\"w-3 h-3 text-amber-400 flex-shrink-0\" />\n                      )}\n                    </div>\n                    <p className={`text-[10px] mt-1 line-clamp-1 opacity-70`}>\n                      {chap.subtitle}\n                    </p>\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n        </section>\n\n        {/* Center: Beautiful Reading Pane */}\n        <section className=\"lg:col-span-6 flex flex-col space-y-4\">\n          <div className={`flex-1 p-6 md:p-8 rounded-3xl border ${themeClasses.cardBg} transition-all duration-300 flex flex-col relative overflow-hidden min-h-[500px]`}>\n            \n            {/* Reading header with chapter navigation shortcuts */}\n            <div className=\"flex items-center justify-between border-b border-slate-800/40 pb-4 mb-5\">\n              <button\n                disabled={selectedId <= 1}\n                onClick={() => {\n                  setSelectedId(prev => Math.max(1, prev - 1));\n                  if (scrollContainerRef.current) scrollContainerRef.current.scrollTop = 0;\n                }}\n                className={`p-1.5 rounded-lg border border-slate-800 transition-colors ${\n                  selectedId <= 1 ? \"opacity-30 cursor-not-allowed\" : \"hover:bg-slate-800 text-amber-400\"\n                }`}\n                title=\"\344\270\212\344\270\200\347\253\240\"\n              >\n                <ChevronLeft className=\"w-4 h-4\" />\n              </button>\n\n              <div className=\"text-center max-w-[70%]\">\n                <span className={`text-[10px] uppercase tracking-widest font-mono ${themeClasses.textMuted}`}>\n                  {currentChapter.subtitle}\n                </span>\n                <h3 className=\"text-lg font-bold font-serif mt-0.5 truncate tracking-wide\">\n                  {currentChapter.title}\n                </h3>\n              </div>\n\n              <button\n                disabled={selectedId >= chapters.length}\n                onClick={() => {\n                  setSelectedId(prev => Math.min(chapters.length, prev + 1));\n                  if (scrollContainerRef.current) scrollContainerRef.current.scrollTop = 0;\n                }}\n                className={`p-1.5 rounded-lg border border-slate-800 transition-colors ${\n                  selectedId >= chapters.length ? \"opacity-30 cursor-not-allowed\" : \"hover:bg-slate-800 text-amber-400\"\n                }`}\n                title=\"\344\270\213\344\270\200\347\253\240\"\n              >\n                <ChevronRight className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            {/* Custom selection metadata or notice */}\n            {currentChapter.isAiGenerated && (\n              <div className=\"mb-4 p-2.5 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-between text-[11px]\">\n                <span className=\"text-amber-300 flex items-center gap-1.5 font-mono\">\n                  <Sparkles className=\"w-3.5 h-3.5\" />\n                  \346\255\244\347\253\240\350\212\202\344\270\272 AI \347\273\255\345\206\231\343\200\202\346\240\271\346\215\256\350\265\260\345\220\221\357\274\232\343\200\216{currentChapter.promptUsed}\343\200\217\347\224\237\346\210\220\n                </span>\n                <button\n                  onClick={deleteCurrentChapter}\n                  className=\"text-red-400 hover:text-red-300 font-mono flex items-center gap-0.5\"\n                  title=\"\345\210\240\351\231\244\345\275\223\345\211\215AI\347\253\240\350\212\202\"\n                >\n                  <Trash2 className=\"w-3 h-3\" />\n                  <span>\351\224\200\346\257\201</span>\n                </button>\n              </div>\n            )}\n\n            {/* Actual Novel content render frame */}\n            <div \n              ref={scrollContainerRef}\n              className={`flex-1 overflow-y-auto pr-3 leading-relaxed whitespace-pre-wrap transition-all duration-300 ${settings.fontFamily} ${themeClasses.readerBg} p-4 rounded-xl border border-transparent`}\n              style={{ fontSize: `${settings.fontSize}px`, maxHeight: \"60vh\" }}\n            >\n              {currentChapter.content}\n            </div>\n\n            {/* End of chapter status/navigator bar */}\n            <div className=\"mt-5 border-t border-slate-800/40 pt-4 flex items-center justify-between text-xs text-slate-500 font-mono\">\n              <span>\351\230\205\350\257\273\350\277\233\345\272\246: {Math.round((selectedId / chapters.length) * 100)}% ({selectedId}/{chapters.length})</span>\n              <span>\345\255\227\346\225\260\347\273\237\350\256\241: ~{currentChapter.content.length} \345\255\227</span>\n            </div>\n          </div>\n        </section>\n\n        {/* Right Side: AI Plot Continuation Console */}\n        <section className=\"lg:col-span-3 flex flex-col space-y-4\">\n          <div className={`p-5 rounded-3xl border ${themeClasses.cardBg} transition-all duration-300 flex flex-col space-y-4`}>\n            \n            <div className=\"flex items-center space-x-1.5\">\n              <Compass className=\"w-4.5 h-4.5 text-amber-400\" />\n              <h2 className=\"text-sm font-semibold tracking-wider font-serif\">\347\245\236\350\257\206\347\273\255\345\206\231\346\216\247\345\210\266\345\217\260</h2>\n            </div>\n\n            <p className={`text-xs ${themeClasses.textMuted} leading-relaxed`}>\n              \345\234\250\346\255\244\350\276\223\345\205\245\346\202\250\346\204\217\346\203\263\347\232\204\345\256\277\345\221\275\350\265\260\345\220\221\346\210\226\345\217\214\344\277\256\345\220\216\347\273\255\343\200\202\347\202\271\345\207\273\344\270\213\346\226\271\351\207\221\344\270\271\357\274\214\350\260\203\347\224\250 <span className=\"text-amber-400 font-mono\">Gemini 3.5</span> \345\205\203\345\251\264\347\247\230\346\234\257\357\274\214\345\215\263\345\217\257\350\256\251\346\225\205\344\272\213\350\207\252\345\212\250\347\274\226\347\273\207\343\200\201\346\227\240\351\231\220\345\273\266\347\273\265\343\200\202\n            </p>\n\n            {/* Preset Directions selector */}\n            <div className=\"space-y-2\">\n              <span className={`text-[11px] font-mono tracking-wider ${themeClasses.textMuted} uppercase block`}>\n                \345\277\253\346\215\267\345\211\247\346\203\205\346\216\250\346\274\224\357\274\232\n              </span>\n              <div className=\"flex flex-wrap gap-1.5 max-h-[180px] overflow-y-auto pr-1\">\n                {PRESET_PROMPTS.map((preset, idx) => (\n                  <button\n                    key={idx}\n                    onClick={() => selectPresetPrompt(preset)}\n                    className={`text-[11px] px-2.5 py-1.5 rounded-xl border transition-all text-left w-full truncate ${\n                      prompt === preset \n                        ? \"bg-amber-500/20 text-amber-300 border-amber-500\" \n                        : `border-slate-800 bg-slate-950/40 hover:bg-slate-900 text-slate-300`\n                    }`}\n                  >\n                    {idx + 1}. {preset}\n                  </button>\n                ))}\n              </div>\n            </div>\n\n            {/* Manual user prompt input */}\n            <div className=\"space-y-1.5\">\n              <label className={`text-[11px] font-mono tracking-wider ${themeClasses.textMuted} uppercase`}>\n                \350\207\252\345\256\232\346\274\224\345\214\226\350\265\260\345\220\221\357\274\232\n              </label>\n              <textarea\n                value={prompt}\n                onChange={(e) => setPrompt(e.target.value)}\n                placeholder=\"\344\276\213\345\246\202\357\274\232\345\215\227\345\256\253\345\251\211\346\216\250\345\274\200\351\235\231\345\256\244\347\232\204\345\244\247\351\227\250\357\274\214\347\234\213\345\210\260\345\256\213\347\216\211\350\267\250\345\235\220\345\234\250\351\237\251\347\253\213\350\272\253\344\270\212\357\274\214\350\204\270\350\211\262\347\205\236\347\231\275\343\200\202\345\256\213\347\216\211\351\235\242\344\270\215\346\224\271\350\211\262\357\274\214\345\200\237\345\215\227\345\256\253\345\270\210\345\247\220\347\232\204\345\216\213\345\212\233\345\274\272\350\241\214\345\206\262\345\210\272...\"\n                rows={4}\n                className={`w-full p-3 rounded-xl border text-xs focus:ring-1 focus:ring-amber-500 focus:outline-none transition-all resize-none ${themeClasses.inputBg}`}\n                maxLength={200}\n              />\n              <div className=\"text-right text-[10px] text-slate-500\">\n                {prompt.length}/200 \345\255\227\n              </div>\n            </div>\n\n            {/* Action Buttons & error display */}\n            <div className=\"space-y-3.5 pt-2\">\n              {errorMsg && (\n                <div className=\"p-3 rounded-xl bg-red-950/40 border border-red-800 text-[11px] text-red-300 leading-relaxed font-mono\">\n                  {errorMsg}\n                </div>\n              )}\n\n              <button\n                onClick={generateNextChapter}\n                disabled={isGenerating || !prompt.trim()}\n                className={`w-full py-3 px-4 rounded-xl font-serif text-sm tracking-wider flex items-center justify-center space-x-2 transition-all ${\n                  isGenerating || !prompt.trim()\n                    ? \"bg-slate-800 text-slate-500 cursor-not-allowed opacity-50\"\n                    : themeClasses.accentBtn\n                }`}\n              >\n                {isGenerating ? (\n                  <>\n                    <Loader2 className=\"w-4 h-4 animate-spin text-slate-950\" />\n                    <span>\346\255\243\345\234\250\345\207\235\347\273\203\347\257\207\347\253\240...</span>\n                  </>\n                ) : (\n                  <>\n                    <Sparkles className=\"w-4 h-4\" />\n                    <span>AI \347\247\230\346\234\257\357\274\232\347\273\255\345\206\231\344\270\213\344\270\200\345\215\267</span>\n                  </>\n                )}\n              </button>\n            </div>\n          </div>\n        </section>\n      </main>\n\n      {/* Full screen Immersive Loader when generating chapter */}\n      {isGenerating && (\n        <div className=\"fixed inset-0 bg-slate-950/95 z-50 flex flex-col items-center justify-center p-6 backdrop-blur-md animate-fadeIn\">\n          <div className=\"max-w-md w-full text-center space-y-6\">\n            <div className=\"relative inline-block\">\n              <div className=\"w-24 h-24 rounded-full border-4 border-amber-500/20 border-t-amber-400 animate-spin flex items-center justify-center\">\n                <BookOpenText className=\"w-10 h-10 text-amber-400 animate-pulse\" />\n              </div>\n              <div className=\"absolute -inset-1 bg-amber-500/10 rounded-full blur-xl animate-pulse\"></div>\n            </div>\n\n            <div className=\"space-y-2\">\n              <h3 className=\"text-lg font-bold font-serif text-amber-300 tracking-wider\">\n                \347\201\265\344\277\256\344\272\244\346\263\260\357\274\214\345\221\250\345\244\251\347\274\226\347\273\207\344\270\255\n              </h3>\n              <p className=\"text-xs text-slate-400 max-w-xs mx-auto\">\n                \345\205\203\345\251\264\344\270\216\347\273\223\344\270\271\347\232\204\345\244\247\350\267\250\345\272\246\344\272\244\350\236\215\346\255\243\345\234\250\346\261\207\345\205\245\346\267\267\346\262\214\350\231\232\346\227\240\357\274\214\350\257\267\350\200\220\345\277\203\347\255\211\345\276\205\347\245\236\351\255\202\347\201\265\346\204\237\346\230\276\347\216\260\343\200\202\n              </p>\n            </div>\n\n            <div className=\"p-4 rounded-2xl bg-slate-900 border border-slate-800 shadow-inner\">\n              <p className=\"text-xs font-mono text-amber-400 transition-all duration-500 animate-pulse\">\n                {loadingStep}\n              </p>\n            </div>\n\n            <div className=\"flex justify-center space-x-2\">\n              <span className=\"w-2 h-2 bg-amber-500 rounded-full animate-bounce\"></span>\n              <span className=\"w-2 h-2 bg-amber-500 rounded-full animate-bounce [animation-delay:0.2s]\"></span>\n              <span className=\"w-2 h-2 bg-amber-500 rounded-full animate-bounce [animation-delay:0.4s]\"></span>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Simple styled footer */}\n      <footer className=\"text-center py-6 text-[11px] text-slate-600 font-mono mt-auto relative z-10\">\n        \350\220\275\344\272\221\345\256\227\347\277\240\347\253\271\350\275\251\345\207\272\345\223\201 \302\251 2026 \350\220\275\344\272\221\344\277\256\344\273\231\344\274\240\357\274\232\347\201\265\350\214\266\347\247\230\350\257\235 \342\200\242 \345\235\232\350\213\245\347\243\220\347\237\263\347\232\204\345\205\203\351\230\263\347\240\264\350\243\202\n      </footer>\n    </div>\n  );\n}\n"
    }
