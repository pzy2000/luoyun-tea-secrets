        }
        lines {
          text: "      if (isQuote) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        className += `italic ${themeClasses.accentText} font-serif font-medium `;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      } else {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        className += \"opacity-90 font-serif \";"
