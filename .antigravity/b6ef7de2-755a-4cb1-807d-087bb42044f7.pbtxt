        lines {
          text: "  // Convert chapter index to uppercase Roman numeral or styled digit"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const getRomanNumeral = (num: number) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const romans = [\"I\", \"II\", \"III\", \"IV\", \"V\", \"VI\", \"VII\", \"VIII\", \"IX\", \"X\", \"XI\", \"XII\"];"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    return romans[num - 1] || num.toString().padStart(2, \'0\');"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
