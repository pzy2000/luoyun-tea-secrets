        lines {
          text: "  // Parse chapter content into paragraphs for elegant editorial formatting"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const renderEditorialContent = (content: string) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const paragraphs = content.split(\"\\n\").map(p => p.trim()).filter(Boolean);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    return paragraphs.map((para, index) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const isQuote = para.startsWith(\"\342\200\234\") || para.startsWith(\"\342\200\230\") || para.startsWith(\"\343\200\220\") || para.includes(\"\342\200\234\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      let className = \"mb-8 text-justify leading-[1.85] tracking-wide \";"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (index === 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        className += \"dropcap \";"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      "
